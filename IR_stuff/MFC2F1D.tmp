//structs
//simpledecode struc
typedef struct {
    uint8_t  protocol;
    uint16_t address;
    uint16_t command;
} simple_dec_t;
//defs
//rca vars
#define RC5_HALF_BIT   889
#define RC6_HALF_BIT   444

// Simple protocol IDs
#define PROTO_SIMPLE_UNKNOWN   0
#define PROTO_SIMPLE_NEC       1
#define PROTO_SIMPLE_NECEXT    2
#define PROTO_SIMPLE_NEC42     3
#define PROTO_SIMPLE_NEC42EXT  4
#define PROTO_SIMPLE_SAMSUNG   5
#define PROTO_SIMPLE_RC5       6
#define PROTO_SIMPLE_RC5X      7
#define PROTO_SIMPLE_RC6       8
#define PROTO_SIMPLE_RCA       9
#define PROTO_SIMPLE_KASEIKYO 10
#define PROTO_SIMPLE_PIONEER  11
#define PROTO_SIMPLE_SIRC     12
#define PROTO_SIMPLE_SIRC15   13
#define PROTO_SIMPLE_SIRC20   14

//joystick pins (left shifted tactile sw)
#define JS_LEFT   GPIOD, GPIO_PIN_4
#define JS_DOWN   GPIOD, GPIO_PIN_6
#define JS_RIGHT  GPIOD, GPIO_PIN_7
#define JS_UP 	  GPIOB, GPIO_PIN_2
#define JS_OK     GPIOB, GPIO_PIN_1
//defs masking
#define JS_Right()  GPIO_ReadInputPin(JS_RIGHT) == RESET
#define JS_Left()   GPIO_ReadInputPin(JS_LEFT) == RESET
#define JS_Down()   GPIO_ReadInputPin(JS_DOWN) == RESET    
#define JS_Up() GPIO_ReadInputPin(JS_UP) == RESET    
#define JS_Ok() GPIO_ReadInputPin(JS_OK) == RESET   
//vars
volatile uint8_t pulse_count;
volatile uint8_t col=0;
volatile uint8_t capture_done;
volatile uint8_t first_edge = 0;      // reset to 1 at start of capture
volatile uint16_t pulses[MAX_PULSES];
volatile uint16_t last_edge=0;
volatile uint8_t dly_counter;
volatile uint32_t ms_counter;
uint16_t i,j;
//display items after decoding
simple_dec_t SimpleDecode(const uint16_t *pulses, uint16_t count);
void clock_setup(void);
void EXTI_setup(void);
void TIM5_setup(void);
void TIM6_setup(void);
void TIM1_setup(void);
void rx_cleanup(void);
void JS_init(void);
void ReceiveIR(void);
void SendIR(const uint16_t *data, uint8_t count,
                         uint16_t freq_hz, uint8_t duty_pc);
void main(void)
{
    clock_setup();
		HD1650_init();
		HD1650_displayOn();
		HD1650_clearDisplay();
		//HD1650_sendDigit("ABCD", 1);
		//JS_init();
		ReceiveIR();
		

}
